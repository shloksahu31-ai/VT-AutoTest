# E2E Testing Environment Variables
# Copy this file to .env.e2e and fill in the values

# Base URL of the staging environment
E2E_BASE_URL=https://staging-demo.vacaturetovenaar.nl

# Login credentials for E2E tests (replace with actual staging credentials)
E2E_USERNAME=your-test-user@example.com
E2E_PASSWORD=your-test-password

# Backend API URL (the studio's backend proxy)
E2E_BACKEND_URL=https://staging-demo.vacaturetovenaar.nl

# Tenant ID override (auto-extracted from E2E_BASE_URL hostname if not set)
# E2E_TENANT_ID=staging-demo

# Google AI API key for LLM-as-judge quality scoring (Gemini Flash)
GOOGLE_AI_API_KEY=AIzaSyB5EZa24f9EZAI-aUM-ylyR-FnWeHxa88s
